import os
import time
import cv2
import numpy as np


def read_image_with_chinese_path(input_path):
    """
    读取图片，兼容中文路径。
    """
    image_data = np.fromfile(input_path, dtype=np.uint8)
    image = cv2.imdecode(image_data, cv2.IMREAD_COLOR)
    return image


def save_image_with_chinese_path(save_path, image):
    """
    保存图片，兼容中文路径。
    """
    success, encoded_image = cv2.imencode(".png", image)

    if not success:
        raise ValueError("处理后的图片保存失败")

    encoded_image.tofile(save_path)


def resize_image(image, max_width=1600, min_width=900):
    """
    自适应缩放图片。

    太大的图片缩小，避免处理速度慢；
    太小的图片适当放大，方便 OCR 识别小字。
    """
    height, width = image.shape[:2]

    if width > max_width:
        scale = max_width / width
        new_width = max_width
        new_height = int(height * scale)

        image = cv2.resize(
            image,
            (new_width, new_height),
            interpolation=cv2.INTER_AREA
        )

        print(f"图片过大，已缩小为：{new_width} × {new_height}")

    elif width < min_width:
        scale = min_width / width
        new_width = min_width
        new_height = int(height * scale)

        image = cv2.resize(
            image,
            (new_width, new_height),
            interpolation=cv2.INTER_CUBIC
        )

        print(f"图片较小，已放大为：{new_width} × {new_height}")

    else:
        print("图片尺寸合适，不需要缩放")

    return image


def auto_contrast(gray_image):
    """
    自动对比度拉伸。

    作用：
    让文字和背景的差异更明显，
    但不会像二值化那样把复杂图片变成线稿。
    """
    low, high = np.percentile(gray_image, (2, 98))

    if high - low < 10:
        return gray_image

    result = np.clip((gray_image - low) * 255.0 / (high - low), 0, 255)
    return result.astype(np.uint8)


def safe_skew_correction(gray_image):
    """
    安全的文本倾斜矫正。

    注意：
    只在检测到比较可靠的小角度倾斜时才旋转。
    如果图片内容复杂，或者角度不可信，就自动跳过。
    """

    # 使用 OTSU 临时二值化，仅用于检测角度，不作为最终输出
    _, binary = cv2.threshold(
        gray_image,
        0,
        255,
        cv2.THRESH_BINARY + cv2.THRESH_OTSU
    )

    # 边缘检测
    edges = cv2.Canny(binary, 50, 150, apertureSize=3)

    # 检测直线
    lines = cv2.HoughLinesP(
        edges,
        rho=1,
        theta=np.pi / 180,
        threshold=120,
        minLineLength=gray_image.shape[1] // 5,
        maxLineGap=20
    )

    if lines is None:
        print("未检测到可靠文本方向，跳过倾斜矫正")
        return gray_image, 0

    angles = []

    for line in lines:
        x1, y1, x2, y2 = line[0]

        if x2 == x1:
            continue

        angle = np.degrees(np.arctan2(y2 - y1, x2 - x1))

        # 只保留接近水平的角度
        if -10 <= angle <= 10:
            angles.append(angle)

    if len(angles) < 3:
        print("可靠水平线数量不足，跳过倾斜矫正")
        return gray_image, 0

    median_angle = np.median(angles)

    # 角度太小，不需要处理
    if abs(median_angle) < 0.3:
        print("图片倾斜角度很小，不需要矫正")
        return gray_image, median_angle

    # 角度太大，可能是复杂图片误判
    if abs(median_angle) > 5:
        print("检测到的倾斜角度较大，可能误判，跳过倾斜矫正")
        return gray_image, median_angle

    height, width = gray_image.shape[:2]
    center = (width // 2, height // 2)

    rotation_matrix = cv2.getRotationMatrix2D(center, median_angle, 1.0)

    corrected = cv2.warpAffine(
        gray_image,
        rotation_matrix,
        (width, height),
        flags=cv2.INTER_CUBIC,
        borderMode=cv2.BORDER_REPLICATE
    )

    print(f"已进行倾斜矫正，角度：{median_angle:.2f}°")

    return corrected, median_angle


def import_and_preprocess_image(input_path, output_folder="processed_images", max_width=1600):
    """
    图片导入与预处理总函数。

    统一适用于：
    1. 普通文字图片
    2. 表格截图
    3. 软件界面截图
    4. 游戏界面截图
    5. 拍照图片

    不需要手动区分图片类型。

    处理流程：
    1. 检查图片路径是否存在
    2. 检查图片格式是否支持
    3. 自动创建输出文件夹
    4. 读取图片，兼容中文路径
    5. 自适应缩放
    6. 灰度化
    7. 温和去噪
    8. 自动对比度增强
    9. CLAHE 局部增强
    10. 轻微锐化
    11. 安全倾斜矫正
    12. 保存处理后图片
    13. 返回处理后图片路径

    参数：
        input_path: 原始图片路径
        output_folder: 处理后图片保存文件夹
        max_width: 图片最大宽度

    返回：
        processed_image_path: 处理后的图片路径
    """

    supported_types = (".jpg", ".jpeg", ".png", ".bmp", ".webp")

    if not os.path.exists(input_path):
        raise FileNotFoundError("图片文件不存在，请检查路径是否正确")

    if not input_path.lower().endswith(supported_types):
        raise ValueError("图片格式不支持，请选择 jpg、jpeg、png、bmp 或 webp 图片")

    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    image = read_image_with_chinese_path(input_path)

    if image is None:
        raise ValueError("图片读取失败，可能是图片损坏或格式异常")

    height, width = image.shape[:2]
    channels = image.shape[2] if len(image.shape) == 3 else 1

    print("图片读取成功")
    print(f"原始图片路径：{input_path}")
    print(f"图片宽度：{width}")
    print(f"图片高度：{height}")
    print(f"图片通道数：{channels}")

    # 自适应缩放
    image = resize_image(image, max_width=max_width)

    # 转换为灰度图
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    # 温和去噪：保留文字边缘
    denoised = cv2.bilateralFilter(
        gray,
        d=5,
        sigmaColor=40,
        sigmaSpace=40
    )

    # 自动对比度增强
    contrasted = auto_contrast(denoised)

    # CLAHE 局部增强
    clahe = cv2.createCLAHE(
        clipLimit=2.0,
        tileGridSize=(8, 8)
    )
    enhanced = clahe.apply(contrasted)

    # 轻微锐化
    blurred = cv2.GaussianBlur(enhanced, (0, 0), 1)

    sharpened = cv2.addWeighted(
        enhanced,
        1.35,
        blurred,
        -0.35,
        0
    )

    # 安全倾斜矫正
    corrected, angle = safe_skew_correction(sharpened)

    # 为了兼容部分 OCR 模块，转回三通道保存
    result_image = cv2.cvtColor(corrected, cv2.COLOR_GRAY2BGR)

    # 生成文件名
    file_name = f"preprocessed_{int(time.time())}.png"

    processed_image_path = os.path.join(output_folder, file_name)

    # 保存处理后的图片
    save_image_with_chinese_path(processed_image_path, result_image)

    processed_image_path = os.path.abspath(processed_image_path)

    print("图片预处理完成")
    print("已完成：缩放、灰度化、温和去噪、自动增强、局部增强、轻微锐化、安全倾斜矫正")
    print(f"最终倾斜角度：{angle:.2f}°")
    print(f"处理后的图片已保存到：{processed_image_path}")

    return processed_image_path
