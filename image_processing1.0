import os
import time
import cv2
import numpy as np


# 支持的图片格式
SUPPORTED_IMAGE_TYPES = (".jpg", ".jpeg", ".png", ".bmp", ".webp")


def is_supported_image(file_path):
    """
    判断图片格式是否支持
    """
    return file_path.lower().endswith(SUPPORTED_IMAGE_TYPES)


def read_image(file_path):
    """
    读取本地图片，兼容中文路径
    """

    # 检查图片路径是否存在
    if not os.path.exists(file_path):
        raise FileNotFoundError("图片文件不存在，请检查路径是否正确")

    # 检查图片格式是否支持
    if not is_supported_image(file_path):
        raise ValueError("图片格式不支持，请选择 jpg、jpeg、png、bmp 或 webp 图片")

    # 兼容中文路径读取图片
    image_data = np.fromfile(file_path, dtype=np.uint8)
    image = cv2.imdecode(image_data, cv2.IMREAD_COLOR)

    if image is None:
        raise ValueError("图片读取失败，可能是图片损坏或格式异常")

    return image


def resize_image(image, max_width=1600):
    """
    如果图片宽度超过 max_width，则按比例缩小
    """

    height, width = image.shape[:2]

    if width <= max_width:
        return image

    scale = max_width / width
    new_width = max_width
    new_height = int(height * scale)

    resized_image = cv2.resize(
        image,
        (new_width, new_height),
        interpolation=cv2.INTER_AREA
    )

    return resized_image


def save_image(file_path, image):
    """
    保存图片，兼容中文路径
    """

    ext = os.path.splitext(file_path)[1]

    if ext == "":
        ext = ".png"
        file_path += ext

    success, encoded_image = cv2.imencode(ext, image)

    if not success:
        raise ValueError("图片保存失败")

    encoded_image.tofile(file_path)


def get_image_info(file_path):
    """
    获取图片基本信息
    """

    image = read_image(file_path)

    height, width = image.shape[:2]

    if len(image.shape) == 3:
        channels = image.shape[2]
    else:
        channels = 1

    return {
        "path": file_path,
        "width": width,
        "height": height,
        "channels": channels
    }


def import_and_preprocess_image(input_path, output_folder="processed_images", max_width=1600):
    """
    图片导入与预处理总函数

    功能：
    1. 检查图片路径是否存在
    2. 检查图片格式是否支持
    3. 自动新建保存处理后图片的文件夹
    4. 读取图片，兼容中文路径
    5. 获取图片基本信息
    6. 调整图片大小
    7. 转换为灰度图
    8. 轻微去噪
    9. 背景光照校正
    10. 局部对比度增强
    11. 加深文字颜色
    12. 保存处理后的图片
    13. 返回处理后的图片路径

    参数：
        input_path: 原始图片路径
        output_folder: 处理后图片保存文件夹，默认 processed_images
        max_width: 图片最大宽度，默认 1600

    返回：
        processed_image_path: 处理后的图片路径
    """

    # 1. 自动新建保存文件夹
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    # 2. 读取图片
    image = read_image(input_path)

    # 3. 获取原始图片信息
    height, width = image.shape[:2]

    if len(image.shape) == 3:
        channels = image.shape[2]
    else:
        channels = 1

    print("图片读取成功")
    print(f"原始图片路径：{input_path}")
    print(f"图片宽度：{width}")
    print(f"图片高度：{height}")
    print(f"图片通道数：{channels}")

    # 4. 如果图片太大，则按比例缩小
    image = resize_image(image, max_width=max_width)

    new_height, new_width = image.shape[:2]

    if new_width != width:
        print(f"图片已缩放为：{new_width} × {new_height}")
    else:
        print("图片尺寸未超过限制，不需要缩放")

    # 5. 转换为灰度图
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    # 6. 轻微去噪
    # bilateralFilter 可以保留文字边缘，同时减少噪声
    denoised = cv2.bilateralFilter(gray, 5, 50, 50)

    # 7. 背景光照校正
    # 用大范围模糊估计背景，再消除纸张阴影和底纹
    background = cv2.GaussianBlur(denoised, (31, 31), 0)
    corrected = cv2.divide(denoised, background, scale=255)

    # 8. 局部对比度增强
    # CLAHE 比 equalizeHist 更温和，不容易把背景噪点放大
    clahe = cv2.createCLAHE(
        clipLimit=1.5,
        tileGridSize=(8, 8)
    )

    enhanced = clahe.apply(corrected)

    # 9. 轻微锐化，让文字边缘更清楚
    blur = cv2.GaussianBlur(enhanced, (3, 3), 0)

    sharpened = cv2.addWeighted(
        enhanced,
        1.5,
        blur,
        -0.5,
        0
    )

    # 10. 只加深文字区域，不明显加深背景
    final_image = sharpened.copy()

    # 灰度图中，数值越小越黑
    # 小于 180 的区域大多是文字、线条
    text_mask = final_image < 180

    final_image[text_mask] = np.clip(
        final_image[text_mask] * 0.65,
        0,
        255
    ).astype(np.uint8)

    # 11. 轻微提亮背景，避免纸张底纹太明显
    final_image = cv2.convertScaleAbs(
        final_image,
        alpha=1.05,
        beta=5
    )

    # 12. 生成处理后图片文件名
    file_name = f"preprocessed_{int(time.time())}.png"

    # 13. 拼接保存路径
    processed_image_path = os.path.join(output_folder, file_name)

    # 14. 保存处理后的图片
    save_image(processed_image_path, final_image)

    # 15. 转成绝对路径，方便其他模块调用
    processed_image_path = os.path.abspath(processed_image_path)

    print("图片预处理完成")
    print(f"处理后的图片已保存到：{processed_image_path}")

    return processed_image_path


def preprocess_image(input_path, output_dir="processed_images"):
    """
    兼容旧代码的函数名

    如果之前其他地方调用的是 preprocess_image，
    这个函数也可以正常工作。
    """

    return import_and_preprocess_image(
        input_path=input_path,
        output_folder=output_dir
    )


if __name__ == "__main__":
    """
    单独测试 processed.py 时使用
    """

    test_path = input("请输入图片路径：")

    try:
        result_path = import_and_preprocess_image(test_path)
        print("最终处理结果路径：")
        print(result_path)

    except Exception as e:
        print("图片处理失败：")
        print(e)
