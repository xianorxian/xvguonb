import os
import time
import cv2
import numpy as np


def import_and_preprocess_image(input_path, output_folder="processed_images", max_width=1600):
    """
    图片导入与预处理总函数。

    功能：
    1. 检查图片路径是否存在
    2. 检查图片格式是否支持
    3. 自动新建保存处理后图片的文件夹
    4. 读取图片，兼容中文路径
    5. 获取图片基本信息
    6. 调整图片大小
    7. 转换为灰度图
    8. 轻微去噪
    9. 增强对比度
    10. 将处理后的图片保存到新建文件夹中
    11. 返回处理后的图片路径

    参数：
        input_path: 原始图片路径
        output_folder: 处理后图片保存文件夹，默认 processed_images
        max_width: 图片最大宽度，默认 1600

    返回：
        processed_image_path: 处理后的图片路径
    """

    # 支持的图片格式
    supported_types = (".jpg", ".jpeg", ".png", ".bmp", ".webp")

    # 检查图片路径是否存在
    if not os.path.exists(input_path):
        raise FileNotFoundError("图片文件不存在，请检查路径是否正确")

    # 检查图片格式是否支持
    if not input_path.lower().endswith(supported_types):
        raise ValueError("图片格式不支持，请选择 jpg、jpeg、png、bmp 或 webp 图片")

    # 自动新建保存处理后图片的文件夹
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    # 读取图片，兼容中文路径
    image_data = np.fromfile(input_path, dtype=np.uint8)
    image = cv2.imdecode(image_data, cv2.IMREAD_COLOR)

    if image is None:
        raise ValueError("图片读取失败，可能是图片损坏或格式异常")

    # 获取图片基本信息
    height, width = image.shape[:2]

    if len(image.shape) == 3:
        channels = image.shape[2]
    else:
        channels = 1

    print("图片读取成功")
    print(f"原始图片路径：{input_path}")
    print(f"图片宽度：{width}")
    print(f"图片高度：{height}")
    print(f"图片通道数：{channels}")

    # 如果图片太大，就按比例缩小
    if width > max_width:
        scale = max_width / width
        new_width = max_width
        new_height = int(height * scale)

        image = cv2.resize(
            image,
            (new_width, new_height),
            interpolation=cv2.INTER_AREA
        )

        print(f"图片已缩放为：{new_width} × {new_height}")
    else:
        print("图片尺寸未超过限制，不需要缩放")

    # 转换为灰度图
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)

    # 轻微去噪
    denoised = cv2.GaussianBlur(gray, (3, 3), 0)

    # 增强对比度
    enhanced = cv2.equalizeHist(denoised)

    # 生成处理后图片文件名
    file_name = f"preprocessed_{int(time.time())}.png"

    # 拼接保存路径：processed_images/preprocessed_xxx.png
    processed_image_path = os.path.join(output_folder, file_name)

    # 保存图片，兼容中文路径
    success, encoded_image = cv2.imencode(".png", enhanced)

    if not success:
        raise ValueError("处理后的图片保存失败")

    encoded_image.tofile(processed_image_path)

    # 转成绝对路径，方便其他模块调用
    processed_image_path = os.path.abspath(processed_image_path)

    print("图片预处理完成")
    print(f"处理后的图片已保存到：{processed_image_path}")

    return processed_image_path
