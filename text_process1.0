from image_process import import_and_preprocess_image


image_path = input("请输入图片路径：")

try:
    processed_path = import_and_preprocess_image(image_path)

    print("测试成功")
    print("图片已经完成导入与预处理")
    print(f"处理后的图片路径：{processed_path}")

except Exception as e:
    print("测试失败")
    print(f"错误原因：{e}")
