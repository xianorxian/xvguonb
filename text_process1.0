import os
import time
import cv2
import numpy as np
from tkinter import Tk, filedialog

from processed import import_and_preprocess_image


def read_image_chinese_path(file_path, mode=cv2.IMREAD_COLOR):
    """
    读取图片，兼容中文路径
    """
    image_data = np.fromfile(file_path, dtype=np.uint8)
    image = cv2.imdecode(image_data, mode)

    if image is None:
        raise ValueError("图片读取失败，请检查图片是否损坏")

    return image


def resize_for_display(image, max_width=600):
    """
    为了方便显示，把图片缩放到合适大小
    """
    height, width = image.shape[:2]

    if width <= max_width:
        return image

    scale = max_width / width
    new_width = max_width
    new_height = int(height * scale)

    return cv2.resize(image, (new_width, new_height), interpolation=cv2.INTER_AREA)


def create_compare_image(original_image, processed_image):
    """
    创建原图和处理后图片的左右对比图
    """

    # 如果处理后图片是灰度图，转成三通道，方便拼接
    if len(processed_image.shape) == 2:
        processed_image = cv2.cvtColor(processed_image, cv2.COLOR_GRAY2BGR)

    # 原图也缩放到适合显示的大小
    original_image = resize_for_display(original_image)
    processed_image = resize_for_display(processed_image)

    # 让两张图高度一致
    original_height, original_width = original_image.shape[:2]
    processed_height, processed_width = processed_image.shape[:2]

    target_height = min(original_height, processed_height)

    original_scale = target_height / original_height
    processed_scale = target_height / processed_height

    original_image = cv2.resize(
        original_image,
        (int(original_width * original_scale), target_height)
    )

    processed_image = cv2.resize(
        processed_image,
        (int(processed_width * processed_scale), target_height)
    )

    # 添加标题区域
    title_height = 40

    original_title = np.ones(
        (title_height, original_image.shape[1], 3),
        dtype=np.uint8
    ) * 255

    processed_title = np.ones(
        (title_height, processed_image.shape[1], 3),
        dtype=np.uint8
    ) * 255

    cv2.putText(
        original_title,
        "Original Image",
        (20, 28),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 0, 0),
        2
    )

    cv2.putText(
        processed_title,
        "Processed Image",
        (20, 28),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 0, 0),
        2
    )

    original_with_title = np.vstack((original_title, original_image))
    processed_with_title = np.vstack((processed_title, processed_image))

    compare_image = np.hstack((original_with_title, processed_with_title))

    return compare_image


def save_image_chinese_path(file_path, image):
    """
    保存图片，兼容中文路径
    """
    ext = os.path.splitext(file_path)[1]

    if ext == "":
        ext = ".png"
        file_path += ext

    success, encoded_image = cv2.imencode(ext, image)

    if not success:
        raise ValueError("图片保存失败")

    encoded_image.tofile(file_path)


def choose_image():
    """
    打开文件选择窗口，选择一张图片
    """
    root = Tk()
    root.withdraw()

    file_path = filedialog.askopenfilename(
        title="请选择要处理的图片",
        filetypes=[
            ("图片文件", "*.jpg *.jpeg *.png *.bmp *.webp"),
            ("所有文件", "*.*")
        ]
    )

    return file_path


def main():
    """
    主调函数：
    1. 选择图片
    2. 调用图片预处理函数
    3. 显示处理效果
    4. 保存对比图
    """

    input_path = choose_image()

    if input_path == "":
        print("没有选择图片，程序结束")
        return

    print("你选择的图片是：")
    print(input_path)

    try:
        # 调用你的图片预处理函数
        processed_path = import_and_preprocess_image(input_path)

        print("处理后的图片路径：")
        print(processed_path)

        # 读取原图和处理后的图片
        original_image = read_image_chinese_path(input_path)
        processed_image = read_image_chinese_path(processed_path, cv2.IMREAD_GRAYSCALE)

        # 生成对比图
        compare_image = create_compare_image(original_image, processed_image)

        # 创建对比图保存文件夹
        compare_folder = "compare_images"

        if not os.path.exists(compare_folder):
            os.makedirs(compare_folder)

        compare_path = os.path.join(
            compare_folder,
            f"compare_{int(time.time())}.png"
        )

        save_image_chinese_path(compare_path, compare_image)

        print("对比图已保存到：")
        print(os.path.abspath(compare_path))

        # 显示对比图
        cv2.imshow("Original VS Processed", compare_image)
        cv2.waitKey(0)
        cv2.destroyAllWindows()

    except Exception as e:
        print("图片处理失败：")
        print(e)


if __name__ == "__main__":
    main()
